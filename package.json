{
  "name": "my-nickname-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cd apps/frontend && bun --bun next dev",
    "build": "cd apps/frontend && bun --bun next build",
    "start": "cd apps/frontend && bun --bun next start",
    "lint": "biome check",
    "format": "biome format --write",
    "drizzle:generate": "bun --bun drizzle-kit generate"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "drizzle-orm": "^0.34.0",
    "@neondatabase/serverless": "^0.7.0",
    "drizzle-kit": "^0.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
